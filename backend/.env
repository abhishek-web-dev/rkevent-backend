# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGODB_URI=mongodb://localhost:27017/rk-event-invoice

# JWT Settings
JWT_SECRET=super_secret_rk_event_invoice_key_2026
JWT_EXPIRES_IN=7d

# Cloudinary credentials (for image uploads)
CLOUDINARY_CLOUD_NAME=dummy_cloud_name
CLOUDINARY_API_KEY=dummy_api_key
CLOUDINARY_API_SECRET=dummy_api_secret

# SMTP configuration for email invoices (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=dummy_smtp_user
SMTP_PASS=dummy_smtp_pass
SMTP_FROM_EMAIL=noreply@rkevent.com
SMTP_FROM_NAME="RK Event Invoice System"
